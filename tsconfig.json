{
    "compilerOptions": {
      "outDir": "./dist/",
      "module": "esnext",
      "target": "es6",
      "moduleResolution": "bundler",
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "declaration": false,
      "noImplicitAny": true,
      "removeComments": true,
      "types": ["node", "jest"],
      "skipLibCheck": true,
      "rootDir": "./src"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"]
  }