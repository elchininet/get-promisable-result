{
  "name": "get-promisable-result",
  "version": "2.0.0",
  "description": "A very small JavaScript utility to check and retry a function a limited number of times abstracting it in a Promise",
  "keywords": [
    "promise",
    "promisable",
    "async",
    "promisable-result",
    "javascript",
    "utility",
    "javascript-utility",
    "retry",
    "check-and-retry"
  ],
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    }
  },
  "files": [
    "dist/**/*"
  ],
  "author": "ElChiniNet",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elchininet/get-promisable-result"
  },
  "scripts": {
    "build": "rollup --config rollup.config.js --bundleConfigAsCjs",
    "test:ts": "tsc --noEmit",
    "test:lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test:unit": "jest --clearCache && jest --verbose --coverage",
    "test:all": "pnpm test:ts && pnpm test:lint && pnpm test:unit",
    "prepare": "pnpm build",
    "prepublishOnly": "pnpm test:all",
    "version": "git add .",
    "postversion": "git push && git push --tags"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/eslint": "^9.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "rollup": "4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-tsconfig-paths": "^1.5.2",
    "ts-jest": "^29.4.11",
    "tslib": "^2.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "packageManager": "pnpm@11.11.0"
}
